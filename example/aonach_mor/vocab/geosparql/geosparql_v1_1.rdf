        <schema:description xml:lang="en">The length of a Spatial Object.</schema:description>
        <schema:name xml:lang="en">has length</schema:name>
        <skos:example rdf:resource="http://www.opengis.net/doc/IS/geosparql/1.1#B.1.1.2.7"/>
        <skos:example rdf:resource="http://www.opengis.net/doc/IS/geosparql/1.1#B.1.2.2"/>
      </rdf:Property>
    </rdfs:member>
