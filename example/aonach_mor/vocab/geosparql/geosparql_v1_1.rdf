        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
        <schema:description xml:lang="en">The length of the perimeter of a Spatial Object.</schema:description>
        <schema:name xml:lang="en">has perimeter length</schema:name>
        <skos:example rdf:resource="http://www.opengis.net/doc/IS/geosparql/1.1#B.1.1.1.2"/>
      </rdf:Property>
    </rdfs:member>
    <rdfs:member>
      <rdf:Property rdf:about="http://www.opengis.net/ont/geosparql#hasArea">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasSize"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
        <schema:description xml:lang="en">The area of a Spatial Object.</schema:description>
        <schema:name xml:lang="en">has area</schema:name>
        <skos:example rdf:resource="http://www.opengis.net/doc/IS/geosparql/1.1#B.1.1.2.4"/>
        <skos:example rdf:resource="http://www.opengis.net/doc/IS/geosparql/1.1#B.1.2.2"/>
      </rdf:Property>
    </rdfs:member>
    <rdfs:member>
      <rdf:Property rdf:about="http://www.opengis.net/ont/geosparql#hasVolume">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ObjectProperty"/>
        <rdfs:subPropertyOf rdf:resource="http://www.opengis.net/ont/geosparql#hasSize"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#SpatialObject"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/spatial-object-properties"/>
