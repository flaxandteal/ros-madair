{
  "name": "ros-madair",
  "version": "0.1.0-alpha.4",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "files": [
    "dist",
    "pkg"
  ],
  "main": "./dist/ros-madair.umd.cjs",
  "module": "./dist/ros-madair.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/ros-madair.js",
      "require": "./dist/ros-madair.umd.cjs"
    }
  },
  "scripts": {
    "build:wasm": "wasm-pack build crates/ros-madair-alizarin --target web --out-dir ../../pkg --out-name ros_madair --release",
    "build:js": "vite build && tsc -p tsconfig.build.json",
    "build": "npm run build:wasm && npm run build:js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "alizarin": "https://github.com/flaxandteal/alizarin/releases/download/v0.2.1-alpha.61/alizarin-0.2.1-alpha.61.tgz"
  },
  "devDependencies": {
    "typescript": "~5.6.3",
    "vite": "^5.4.18",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
