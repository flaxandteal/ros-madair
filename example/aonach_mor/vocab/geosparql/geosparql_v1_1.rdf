    <rdfs:member>
      <rdf:Property rdf:about="http://www.opengis.net/ont/geosparql#dimension">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#DatatypeProperty"/>
        <rdfs:domain rdf:resource="http://www.opengis.net/ont/geosparql#Geometry"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/ont/geosparql#"/>
        <rdfs:isDefinedBy rdf:resource="http://www.opengis.net/spec/geosparql/1.1/req/geometry-extension/geometry-properties"/>
        <schema:description xml:lang="en">The topological dimension of this geometric object, which must be less than or equal to the coordinate dimension. In non-homogeneous collections, this will return the largest topological dimension of the contained objects.</schema:description>
